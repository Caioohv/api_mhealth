generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mysql"
}

model User {
  id                String             @id @default(uuid())
  email             String?            @unique
  passwordHash      String?
  googleId          String?            @unique
  name              String
  phone             String?            @unique
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  emergencyAlerts   EmergencyAlert[]
  habitRecords      HabitRecord[]
  sentInvitations   Invitation[]       @relation("InvitationSender")
  medicationIntakes MedicationIntake[]
  networkMembers    NetworkMember[]
  occurrences       Occurrence[]
  createdNetworks   SupportNetwork[]   @relation("NetworkCreator")
}

model SupportNetwork {
  id              String           @id @default(uuid())
  name            String
  description     String?
  creatorId       String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  consultations   Consultation[]
  emergencyAlerts EmergencyAlert[]
  habits          Habit[]
  invitations     Invitation[]
  medications     Medication[]
  members         NetworkMember[]
  occurrences     Occurrence[]
  creator         User             @relation("NetworkCreator", fields: [creatorId], references: [id])

  @@index([creatorId], map: "SupportNetwork_creatorId_fkey")
}

model NetworkMember {
  id                 String          @id @default(uuid())
  userId             String
  networkId          String
  role               NetworkRole
  joinedAt           DateTime        @default(now())
  medicationAccess   PermissionLevel @default(NONE)
  consultationAccess PermissionLevel @default(NONE)
  networkAccess      PermissionLevel @default(NONE)
  recordsAccess      PermissionLevel @default(NONE)
  alertLevel         AlertLevel      @default(ALL)
  network            SupportNetwork  @relation(fields: [networkId], references: [id], onDelete: Cascade)
  user               User            @relation(fields: [userId], references: [id])

  @@unique([userId, networkId])
  @@index([networkId], map: "NetworkMember_networkId_fkey")
}

model Invitation {
  id                 String           @id @default(uuid())
  networkId          String
  inviterId          String
  invitedEmail       String?
  invitedPhone       String?
  status             InvitationStatus @default(PENDING)
  token              String           @unique @default(uuid())
  proposedRole       NetworkRole
  medicationAccess   PermissionLevel  @default(NONE)
  consultationAccess PermissionLevel  @default(NONE)
  networkAccess      PermissionLevel  @default(NONE)
  recordsAccess      PermissionLevel  @default(NONE)
  createdAt          DateTime         @default(now())
  expiresAt          DateTime
  inviter            User             @relation("InvitationSender", fields: [inviterId], references: [id])
  network            SupportNetwork   @relation(fields: [networkId], references: [id], onDelete: Cascade)

  @@index([inviterId], map: "Invitation_inviterId_fkey")
  @@index([networkId], map: "Invitation_networkId_fkey")
}

model Medication {
  id           String               @id @default(uuid())
  networkId    String
  name         String
  dosage       String
  needsBuy     Boolean              @default(false)
  instructions String?              @db.Text
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  network      SupportNetwork       @relation(fields: [networkId], references: [id], onDelete: Cascade)
  intakes      MedicationIntake[]
  schedules    MedicationSchedule[]

  @@index([networkId], map: "Medication_networkId_fkey")
}

model MedicationSchedule {
  id            String     @id @default(uuid())
  medicationId  String
  intervalHours Int?
  intervalDays  Int?
  specificTimes Json?
  startDate     DateTime   @default(now())
  endDate       DateTime?
  medication    Medication @relation(fields: [medicationId], references: [id], onDelete: Cascade)

  @@index([medicationId], map: "MedicationSchedule_medicationId_fkey")
}

model MedicationIntake {
  id           String       @id @default(uuid())
  medicationId String
  takenAt      DateTime     @default(now())
  registeredBy String
  status       IntakeStatus
  notes        String?      @db.Text
  medication   Medication   @relation(fields: [medicationId], references: [id], onDelete: Cascade)
  registrar    User         @relation(fields: [registeredBy], references: [id])

  @@index([medicationId], map: "MedicationIntake_medicationId_fkey")
  @@index([registeredBy], map: "MedicationIntake_registeredBy_fkey")
}

model Consultation {
  id         String           @id @default(uuid())
  networkId  String
  type       ConsultationType @default(CONSULTA)
  title      String
  date       DateTime
  doctorName String?
  specialty  String?
  notes      String?          @db.Text
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  network    SupportNetwork   @relation(fields: [networkId], references: [id], onDelete: Cascade)

  @@index([networkId], map: "Consultation_networkId_fkey")
}

model Occurrence {
  id           String         @id @default(uuid())
  networkId    String
  title        String
  description  String         @db.Text
  type         OccurrenceType
  occurredAt   DateTime
  registeredBy String
  createdAt    DateTime       @default(now())
  network      SupportNetwork @relation(fields: [networkId], references: [id], onDelete: Cascade)
  registrar    User           @relation(fields: [registeredBy], references: [id])

  @@index([networkId], map: "Occurrence_networkId_fkey")
  @@index([registeredBy], map: "Occurrence_registeredBy_fkey")
}

model Habit {
  id          String         @id @default(uuid())
  networkId   String
  name        String
  description String?        @db.Text
  frequency   HabitFrequency
  goal        Int?
  unit        String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  network     SupportNetwork @relation(fields: [networkId], references: [id], onDelete: Cascade)
  records     HabitRecord[]

  @@index([networkId], map: "Habit_networkId_fkey")
}

model HabitRecord {
  id           String   @id @default(uuid())
  habitId      String
  registeredBy String
  value        Int?
  notes        String?  @db.Text
  completedAt  DateTime @default(now())
  habit        Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  registrar    User     @relation(fields: [registeredBy], references: [id])

  @@index([habitId], map: "HabitRecord_habitId_fkey")
  @@index([registeredBy], map: "HabitRecord_registeredBy_fkey")
}

model EmergencyAlert {
  id              String          @id @default(uuid())
  networkId       String
  triggeredBy     String
  message         String?         @db.Text
  status          EmergencyStatus @default(ACTIVE)
  resolvedAt      DateTime?
  createdAt       DateTime        @default(now())
  network         SupportNetwork  @relation(fields: [networkId], references: [id], onDelete: Cascade)
  triggeredByUser User            @relation(fields: [triggeredBy], references: [id])

  @@index([networkId], map: "EmergencyAlert_networkId_fkey")
  @@index([triggeredBy], map: "EmergencyAlert_triggeredBy_fkey")
}

enum NetworkRole {
  RESPONSAVEL
  ASSISTIDO
}

enum AlertLevel {
  ALL
  EMERGENCY_ONLY
  NONE
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELED
}

enum PermissionLevel {
  NONE
  VIEW
  EDIT
}

enum ConsultationType {
  CONSULTA
  PROCEDIMENTO
}

enum IntakeStatus {
  TAKEN
  MISSED
  LATE
}

enum OccurrenceType {
  QUEDA
  MAL_ESTAR
  OBSERVACAO
}

enum HabitFrequency {
  DAILY
  WEEKLY
  CUSTOM
}

enum EmergencyStatus {
  ACTIVE
  RESOLVED
  CANCELED
}
